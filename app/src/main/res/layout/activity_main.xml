<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity"
    android:id="@+id/constraintLayout"
    android:clickable="true"
    android:focusable="true"
    android:background="@color/primary">

    <TextView
        android:id="@+id/txt_score"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="80dp"
        android:layout_marginBottom="8dp"
        android:autoSizeMaxTextSize="34sp"
        android:autoSizeMinTextSize="20sp"
        android:autoSizeStepGranularity="2sp"
        android:autoSizeTextType="uniform"
        android:gravity="center"
        android:maxLines="1"
        android:text="@string/tap_banana_or_emoji"
        android:textColor="@color/white"
        android:textSize="34sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/img_banana"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btn_reset"
        app:layout_constraintVertical_bias="1" />

    <ImageView
        android:id="@+id/img_banana"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintWidth_percent="0.3"
        app:layout_constraintHeight_percent="0.3"
        android:src="@drawable/banana"
        android:contentDescription="@string/banana_image"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btn_rewarded_ad"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.58" />

    <ImageButton
        android:id="@+id/btn_reset"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/ic_reset"
        android:scaleType="fitXY"
        android:background="@null"
        android:contentDescription="@string/reset_score"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="16dp"
        android:layout_marginStart="16dp" />

    <ImageButton
        android:id="@+id/btn_color"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/ic_color"
        android:scaleType="fitXY"
        android:background="@null"
        android:contentDescription="@string/change_background_color"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp" />

    <ImageButton
        android:id="@+id/btn_privacy"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="8dp"
        android:background="@null"
        android:contentDescription="@string/privacy_options"
        android:scaleType="centerInside"
        android:src="@drawable/ic_info"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="@id/btn_color"
        app:layout_constraintTop_toBottomOf="@id/btn_color" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/btn_rewarded_ad"
        android:layout_width="0dp"
        android:layout_height="72dp"
        android:layout_marginHorizontal="18dp"
        android:layout_marginBottom="16dp"
        android:clickable="false"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        app:cardBackgroundColor="#E61A241E"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintWidth_max="420dp"
        app:strokeColor="#55FFFFFF"
        app:strokeWidth="1dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingHorizontal="14dp">

            <ImageView
                android:id="@+id/img_reward_icon"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_reward_icon"
                android:contentDescription="@null"
                android:padding="7dp"
                android:src="@drawable/banana"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/txt_reward_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:letterSpacing="0.04"
                android:text="@string/boost_title"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toTopOf="@id/txt_reward_subtitle"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/img_reward_icon"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_chainStyle="packed" />

            <TextView
                android:id="@+id/txt_reward_subtitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginTop="2dp"
                android:text="@string/ad_loading"
                android:textColor="#CCFFFFFF"
                android:textSize="13sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/img_reward_icon"
                app:layout_constraintTop_toBottomOf="@id/txt_reward_title" />

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/boost_progress"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:indicatorColor="#FFFFD54F"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:trackColor="#33FFFFFF"
                app:trackThickness="3dp" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/txt_emoji_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="88dp"
        android:background="@drawable/bg_rarity_badge"
        android:elevation="6dp"
        android:gravity="center"
        android:letterSpacing="0.06"
        android:minHeight="32dp"
        android:paddingHorizontal="14dp"
        android:paddingVertical="5dp"
        android:textSize="13sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="RARE · +25"
        tools:visibility="visible" />

    <TextView
        android:id="@+id/txt_combo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="126dp"
        android:background="@drawable/bg_combo_badge"
        android:elevation="6dp"
        android:letterSpacing="0.04"
        android:paddingHorizontal="10dp"
        android:paddingVertical="4dp"
        android:textColor="@color/white"
        android:textSize="15sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="COMBO 4 · ×2"
        tools:visibility="visible" />

    <ImageView
        android:id="@+id/img_fun"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="@string/bonus_emoji"
        android:scaleType="fitXY"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>

